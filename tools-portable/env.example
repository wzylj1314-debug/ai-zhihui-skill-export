# Copy this file to .env on the target machine when you want local defaults.
# Do not put real secrets into the exported package.

ZHIHUI_TOOL_HOST=127.0.0.1
ZHIHUI_TOOL_HUB_PORT=8900
ZHIHUI_FAQ_PORT=8899
ZHIHUI_CONVERSATION_PORT=8910

# Optional: override the isolated runtime directory.
# ZHIHUI_RUNTIME_DIR=D:\zhihui-skill-export\runtime

# Optional: connect FAQ commit to a real knowledge base.
# If unset, FAQ drafts and commit attempts stay in skill-export\runtime.
# ZHIHUI_KB_DIR=D:\zhihui-skill-export\runtime\workspace\v1_0_3

# Optional: conversation-analysis model gateway.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5-chat-latest

# Optional: DingTalk channels. Keep these outside the transferred package.
# DINGTALK_WEBHOOK=
# DINGTALK_SECRET=
# DINGTALK_BUSINESS_WEBHOOK=
# DINGTALK_BUSINESS_SECRET=
# DINGTALK_PRODUCT_WEBHOOK=
# DINGTALK_PRODUCT_SECRET=

# Optional: QMD.
# ZHIHUI_QMD_BIN=qmd.cmd
# ZHIHUI_QMD_INDEX_DIR=D:\zhihui-skill-export\runtime\qmd
